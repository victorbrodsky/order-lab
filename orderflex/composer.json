{
    "type": "project",
    "license": "proprietary",
    "name": "oleg/symfony-order",
    "description": "Order web application for pathology, symfony 7.0",
    "require": {
        "php": ">=8.2",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ankitpokhrel/tus-php": "^2.3",
        "asimlqt/php-google-spreadsheet-client": "^3.0",
        "azuyalabs/yasumi": "^2.5",
        "beberlei/doctrineextensions": "^1.5",
        "box/spout": "^3.1",
        "doctrine/doctrine-bundle": "^2.12",
        "doctrine/doctrine-migrations-bundle": "^3.3",
        "doctrine/orm": "^3.2",
        "doctrine/persistence": "^3.0",
        "fabiang/sasl": "^1.0",
        "friendsofsymfony/jsrouting-bundle": "^3.5",
        "google/apiclient": "^2.12.1",
        "knplabs/knp-paginator-bundle": "^6.4",
        "knplabs/knp-snappy-bundle": "^1.10",
        "onelogin/php-saml": "^4.2",
        "oneup/uploader-bundle": "^5.0",
        "phpdocumentor/reflection-docblock": "^5.3",
        "phpoffice/phpspreadsheet": "^1.29",
        "phpseclib/phpseclib": "^3.0",
        "sinergi/browser-detector": "^6.1",
        "spatie/pdf-to-text": "^1.3",
        "stof/doctrine-extensions-bundle": "^1.12",
        "symfony/apache-pack": "^1.0",
        "symfony/asset": "*",
        "symfony/console": "*",
        "symfony/dotenv": "*",
        "symfony/expression-language": "*",
        "symfony/flex": "^2.4",
        "symfony/form": "*",
        "symfony/framework-bundle": "*",
        "symfony/google-mailer": "*",
        "symfony/http-client": "*",
        "symfony/intl": "*",
        "symfony/mailer": "*",
        "symfony/monolog-bundle": "^3.10",
        "symfony/password-hasher": "*",
        "symfony/process": "*",
        "symfony/property-access": "*",
        "symfony/property-info": "*",
        "symfony/runtime": "*",
        "symfony/security-bundle": "*",
        "symfony/serializer": "*",
        "symfony/translation": "*",
        "symfony/twig-bundle": "*",
        "symfony/validator": "*",
        "symfony/web-link": "*",
        "symfony/webpack-encore-bundle": "^2.1",
        "symfony/workflow": "*",
        "symfony/yaml": "*",
        "tattali/calendar-bundle": "^7.0",
        "twig/extra-bundle": "^3.4",
        "twig/string-extra": "^3.4",
        "twilio/sdk": "^6.4"
    },
    "require-dev": {
        "dbrekelmans/bdi": "^1.4",
        "phpunit/phpunit": "^9.6",
        "rector/rector": "*",
        "symfony/browser-kit": "*",
        "symfony/css-selector": "*",
        "symfony/debug-bundle": "*",
        "symfony/maker-bundle": "^1.52",
        "symfony/panther": "^2.1",
        "symfony/phpunit-bridge": "*",
        "symfony/stopwatch": "*",
        "symfony/web-profiler-bundle": "*"
    },
    "config": {
        "platform": {
            "php": "8.3.7"
        },
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "composer/installers": true,
            "third-party/required-plugin": true,
            "unnecessary/plugin": false,
            "symfony/flex": true,
            "symfony/runtime": true
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/App/"
        },
        "classmap": [
            "src/Kernel.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php71": "*",
        "symfony/polyfill-php70": "*",
        "symfony/polyfill-php56": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "pre-autoload-dump": "Google\\Task\\Composer::cleanup"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "^7.0"
        },
        "google/apiclient-services": [
            "Drive"
        ]
    }
}
