If change array to json:
1) Doctrine will detect that the column type changed and will propose a schema change.
2) The column type will change from: text containing serialized PHP (a:11:{...}) to: jsonb (PostgreSQL) containing real JSON (["ROLE_USER", ...])
3) data need to be converted

First convert data, then make migration

public function up(Schema $schema): void
{
    $this->abortIf($this->connection->getDatabasePlatform()->getName() !== 'postgresql', 'Migration can only be executed safely on \'postgresql\'.');

    // 1) Convert legacy PHP-serialized values to JSON while column is still TEXT
    $rows = $this->connection->fetchAllAssociative(
        'SELECT id, roles FROM user_logger WHERE roles IS NOT NULL'
    );
    foreach ($rows as $row) {
        $raw = $row['roles'];

        // Skip values that are already valid JSON (in case some rows were re-saved)
        $decoded = json_decode($raw, true);
        if (json_last_error() === JSON_ERROR_NONE && is_array($decoded)) {
            continue;
        }

        // Old 'array' type stored PHP serialize() output
        $value = @unserialize($raw);
        if ($value === false && $raw !== 'b:0;') {
            $value = []; // corrupt / unexpected -> empty array
        }
        if (!is_array($value)) {
            $value = $value === null ? [] : [$value];
        }

        $this->connection->executeStatement(
            'UPDATE user_logger SET roles = :roles WHERE id = :id',
            ['roles' => json_encode(array_values($value)), 'id' => $row['id']]
        );
    }

    // 2) Now the ALTER cast will succeed because every row is valid JSON
    $this->processSql('ALTER TABLE user_logger ALTER roles TYPE JSON USING roles::json');
    $this->processSql('COMMENT ON COLUMN user_logger.roles IS NULL');
}


