<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>
        {% block title %}
            Welcome!
        {% endblock %}
    </title>
    {#{% block stylesheets %}{% endblock %}#}

    {% block stylesheets_base %}
        {#{{ encore_entry_link_tags('dashboard_base') }}#}
    {% endblock %}
    {% block stylesheets %}
        {#{{ encore_entry_link_tags('app') }}#}
    {% endblock %}

    {% block bootstrapcss %}
        {#<link rel="stylesheet" type="text/css" href="{{ asset('orderassets/AppUserdirectoryBundle/bootstrap/css/bootstrap.min.css') }}" />#}
        <link rel="stylesheet" type="text/css" href="{{ asset('orderassets/AppUserdirectoryBundle/bootstrap/css/bootstrap-theme.min.css') }}" />
        <link rel="stylesheet" type="text/css" href="{{ asset('orderassets/AppUserdirectoryBundle/form/css/form.css') }}" />
    {% endblock %}

    {% block errorwatchjs %}
        <script src="{{ asset('orderassets/AppUserdirectoryBundle/form/js/errorwatch.js') }}"></script>
    {% endblock %}

    {% if security is not defined %}
        {% set security = 'true' %}
    {% endif %}

    {% block maincss %}
        <link rel="stylesheet" type="text/css" href="{{ asset('orderassets/AppUserdirectoryBundle/select2/css/select2.css') }}" />
        <link rel="stylesheet" type="text/css" href="{{ asset('orderassets/AppUserdirectoryBundle/jasny/css/jasny-bootstrap.min.css') }}" />
        <link rel="stylesheet" type="text/css" href="{{ asset('orderassets/AppUserdirectoryBundle/ladda/ladda-themeless.css') }}" />
        <link rel="stylesheet" type="text/css" href="{{ asset('orderassets/AppUserdirectoryBundle/form/css/action.css') }}" />
        <link rel="stylesheet" type="text/css" href="{{ asset('orderassets/AppUserdirectoryBundle/pnotify/pnotify.custom.min.css') }}" />
        <link rel="stylesheet" type="text/css" href="{{ asset('orderassets/AppUserdirectoryBundle/dropzone/css/dropzone.css') }}" />
        <link rel="stylesheet" type="text/css" href="{{ asset('orderassets/AppUserdirectoryBundle/datepicker/css/bootstrap-datepicker3.css') }}" />
        <link rel="stylesheet" type="text/css" href="{{ asset('orderassets/AppUserdirectoryBundle/jquery-ui-1.11.2/themes/smoothness/jquery-ui.css') }}" />
        <link rel="stylesheet" type="text/css" href="{{ asset('orderassets/AppUserdirectoryBundle/form/css/typeahead.css') }}" />
        <link rel="stylesheet" type="text/css" href="{{ asset('orderassets/AppUserdirectoryBundle/fengyuanchen-image-cropper/cropper.min.css') }}" />
        <link rel="stylesheet" type="text/css" href="{{ asset('orderassets/AppUserdirectoryBundle/form/css/crop-avatar.css') }}" />
        <link rel="stylesheet" type="text/css" href="{{ asset('orderassets/AppUserdirectoryBundle/vakata-jstree/themes/default/style.min.css') }}" />
    {% endblock %}

    {% block additionalcss %}{% endblock %}
    {% block additionalcss2 %}{% endblock %}

    {#{% block ie8fixjs %}#}
        {#<script src="{{ asset('orderassets/AppUserdirectoryBundle/html5-bootstrap-fix/html5shiv.min.js') }}"></script>#}
        {#<script src="{{ asset('orderassets/AppUserdirectoryBundle/html5-bootstrap-fix/respond.min.js') }}"></script>#}
    {#{% endblock %}#}

    {% block favicon %}
        {#<link rel="icon" type="image/x-icon" href="{{ asset('orderassets/AppUserdirectoryBundle/form/img/users-1-64x64.png') }}" />#}
        <link rel="icon" type="image/x-icon" href="{{ asset('orderassets/AppCtpBundle/ctp_site/localhost_3000/faviconbcf9.ico') }}" />
    {% endblock %}
</head>
<body>
{% block body %}

    {% block header %}
        {% set ctp_home_bg = '#f8b229' %}
        {% set ctp_newprojectinquiry_bg = '#f8b229' %}
        {% set ctp_people_bg = '#f8b229' %}
        {% set ctp_publications_bg = '#f8b229' %}
        {% set ctp_applications_bg = '#f8b229' %}
        {% if app.request.attributes.get('_route') == 'ctp_home' %}
            {% set ctp_home_bg = '#b31b1b' %}
        {% endif %}
        {% if app.request.attributes.get('_route') == 'ctp_new-project-inquiry' %}
            {% set ctp_newprojectinquiry_bg = '#b31b1b' %}
        {% endif %}
        {% if app.request.attributes.get('_route') == 'ctp_people' %}
            {% set ctp_people_bg = '#b31b1b' %}
        {% endif %}
        {% if app.request.attributes.get('_route') == 'ctp_publications' %}
            {% set ctp_publications_bg = '#b31b1b' %}
        {% endif %}
        {% if app.request.attributes.get('_route') == 'ctp_applications' %}
            {% set ctp_applications_bg = '#b31b1b' %}
        {% endif %}

        <header class="sticky top-0 z-50 bg-gradient-to-r from-[#ffc72c] via-[#ff6a00] to-[#b31b1b] text-white shadow border-b border-white/20 supports-[backdrop-filter]:backdrop-blur-sm">
            <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
                <div class="flex items-center gap-3">
                    <div class="p-1.5 rounded-md bg-white/80 backdrop-blur-sm">
                        <img src="/orderassets/AppCtpBundle/ctp_site/localhost_3000/wcm-logo.png" alt="Weill Cornell Medicine" class="h-10 w-auto"/>
                    </div>
                    <div>
                        <h1 class="text-lg font-semibold leading-tight">Center for Translational Pathology</h1>
                    </div>
                </div>
                <nav class="flex gap-3 flex-wrap">
                    <a class="px-3 py-2 rounded-md text-sm font-medium text-white transition bg-[{{ ctp_home_bg }}] hover:bg-[#b31b1b]"
                       href="{{ path('ctp_home') }}">Home</a>
                    <a class="px-3 py-2 rounded-md text-sm font-medium text-white transition bg-[{{ ctp_newprojectinquiry_bg }}] hover:bg-[#b31b1b]"
                       href="{{ path('ctp_new-project-inquiry') }}">New Project Inquiry</a>
                    <a class="px-3 py-2 rounded-md text-sm font-medium text-white transition bg-[{{ ctp_people_bg }}] hover:bg-[#b31b1b]"
                            {#href="/ctp_site/localhost_3000/people.html"#}
                       href="{{ path('ctp_people') }}"
                    >People</a>
                    <a class="px-3 py-2 rounded-md text-sm font-medium text-white transition bg-[{{ ctp_publications_bg }}] hover:bg-[#b31b1b]"
                       href="{{ path('ctp_publications') }}">Publications</a>
                    <a class="px-3 py-2 rounded-md text-sm font-medium text-white transition bg-[{{ ctp_applications_bg }}] hover:bg-[#b31b1b]"
                       {#href="/ctp_site/localhost_3000/path2path-dashboard-login.html"#}
                       href="{{ path('ctp_applications') }}"
                    >Path2Path Dashboard</a>
                </nav>
            </div>
        </header>
    {% endblock %}


    {% block content_ctp %}
    {% endblock %}

    {% block footer %}
        {#<div class="order-content text-center col-xs-12">#}
            {#<!-- footer -->#}
            {#{% include 'AppUserdirectoryBundle/Default/footer.html.twig' %}#}
        {#</div>#}

        <footer class="mt-8 border-t border-gray-200 py-4 text-center text-sm text-gray-500">
            {#© <!-- -->2026<!-- --> Weill Cornell Medicine · Center for Translational Pathology#}
            {#© <!-- -->2026<!-- --> <a href="weillcornell.org/">Weill Cornell Medicine</a> · Center for Translational Pathology#}
            © <!-- -->2026<!-- --> <a href="https://weillcornell.org/">Weill Cornell Medicine</a> · <a href="{{ path("ctp_home") }}">Center for Translational Pathology</a>
        </footer>

    {% endblock %}

{% endblock %}


{% block javascripts %}
{% endblock %}

</body>
</html>




{#{% block additionalcss %}#}
    {#<link rel="stylesheet" type="text/css" media="screen" href="{{ asset('orderassets/AppUserdirectoryBundle/summernote/summernote.css') }}" />#}
{#{% endblock %}#}
