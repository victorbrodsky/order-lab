{% block content_ctp %}
<main class="min-h-screen bg-[var(--bg)] text-[var(--ink)]">
    <div class="min-h-screen bg-gray-50 flex items-center justify-center px-4">
        <div class="w-full max-w-md rounded-2xl bg-white border border-gray-200 shadow-sm p-6 space-y-6">
            <div class="space-y-1">
                <h1 class="text-xl font-semibold text-[#b31b1b]">Path2Path Dashboard Access</h1>
                <p class="text-xs text-gray-600">Enter your WCM Pathology credentials to access internal CTP tools.</p>
            </div>
            <form class="space-y-4" method="post" action="{{ path('ctp_applications') }}">
                <div class="grid gap-1">
                    <label class="text-sm text-gray-700">Username <span class="text-red-600">*</span></label>
                    <input class="rounded-xl border px-3 py-2 text-sm" placeholder="netid or email" required="" value=""/>
                </div>
                <div class="grid gap-1">
                    <label class="text-sm text-gray-700">Password <span class="text-red-600">*</span></label>
                    <input type="password" class="rounded-xl border px-3 py-2 text-sm" placeholder="••••••••" required="" value=""/>
                </div>
                <button type="submit" class="w-full rounded-xl px-4 py-2 text-sm font-medium text-white transition bg-[#b31b1b] hover:bg-[#a01515]">Enter Dashboard</button>
            </form>
            <div class="text-xs text-gray-500">For demo purposes, any credentials will proceed. Enterprise authentication and fine-grained authorization will be implemented by institutional IT before production deployment.</div>
        </div>
    </div>
</main>
{% endblock %}

{% block footer %}
<footer class="mt-8 border-t border-gray-200 py-4 text-center text-sm text-gray-500">
