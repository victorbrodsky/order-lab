{% extends "AppCtpBundle/Default/base.html.twig" %}

{% block title %}
    New Project - Initial Inquiry - Center for Translational Pathology
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="/orderassets/AppCtpBundle/ctp_site/localhost_3000/_next/static/chunks/node_modules_next_dist_build_polyfills_polyfill-nomodule.js" nomodule></script>
    <script>
        const initialInquiryType = '{{ activeInquiryType|default('wcm') }}';

        document.addEventListener('DOMContentLoaded', function() {
            switchTab(initialInquiryType);
        });

        function switchTab(tab) {
            const wcmBtn = document.getElementById('wcm-tab-btn');
            const externalBtn = document.getElementById('external-tab-btn');
            const wcmForm = document.getElementById('wcm-form');
            const externalForm = document.getElementById('external-form');
            
            if (tab === 'wcm') {
                wcmBtn.classList.add('bg-[#b31b1b]', 'text-white', 'border-[#b31b1b]');
                wcmBtn.classList.remove('bg-white', 'text-[#b31b1b]', 'border-gray-300', 'hover:bg-red-50');
                externalBtn.classList.remove('bg-[#b31b1b]', 'text-white', 'border-[#b31b1b]');
                externalBtn.classList.add('bg-white', 'text-[#b31b1b]', 'border-gray-300', 'hover:bg-red-50');

                wcmForm.style.display = 'block';
                externalForm.style.display = 'none';
            } else {
                externalBtn.classList.add('bg-[#b31b1b]', 'text-white', 'border-[#b31b1b]');
                externalBtn.classList.remove('bg-white', 'text-[#b31b1b]', 'border-gray-300', 'hover:bg-red-50');
                wcmBtn.classList.remove('bg-[#b31b1b]', 'text-white', 'border-[#b31b1b]');
                wcmBtn.classList.add('bg-white', 'text-[#b31b1b]', 'border-gray-300', 'hover:bg-red-50');

                externalForm.style.display = 'block';
                wcmForm.style.display = 'none';
            }
        }
    </script>
{% endblock %}

{% block content_ctp %}
    <main class="min-h-screen bg-[#faf7f5] text-[#1f2937]">

        {# Decorative Background Blurs #}
        {#<div class="pointer-events-none absolute inset-0 overflow-hidden">#}
            {#<div class="absolute -top-32 left-1/2 h-[520px] w-[900px] -translate-x-1/2 rounded-full bg-[#b31b1b]/10 blur-3xl"></div>#}
            {#<div class="absolute top-[280px] right-[-160px] h-[420px] w-[620px] rounded-full bg-[#f6c453]/20 blur-3xl"></div>#}
        {#</div>#}

        <main class="relative mx-auto max-w-3xl px-4 py-12 md:py-16 space-y-6">
        {#<main class="min-h-screen bg-[var(--bg)] text-[var(--ink)]">#}

            {% if validationErrors is defined and validationErrors|length > 0 %}
                <div class="rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-800">
                    <p class="font-semibold">Please complete the required fields:</p>
                    <ul class="mt-2 list-disc pl-5">
                        {% for validationError in validationErrors %}
                            <li>{{ validationError }}</li>
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}
            
            {# Page Header #}
            <div class="space-y-2">
                <h1 class="text-2xl font-semibold text-[#b31b1b]">New Project - Initial Inquiry</h1>
                <p class="text-sm text-gray-700 leading-relaxed">
                    Use this form to submit and propose a new project in collaboration with the Center for Translational Pathology. 
                    <span class="font-medium">WCM investigators and external collaborators can submit requests here without logging in. 
                    We will route the request to the appropriate division and respond within 48 hrs.</span> 
                    Specific internal workflows for internal investigators are available inside the Path2Path Dashboard (login required).
                </p>
            </div>

            {# Request Type Toggle #}
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 border-b border-gray-200 pb-3">
                <div>
                    <h2 class="text-base font-medium text-gray-700">Request Type</h2>
                    <p class="text-xs text-gray-500">Select the type of project request.</p>
                </div>
                <div class="flex flex-wrap gap-2">
                    <button type="button" id="wcm-tab-btn" onclick="switchTab('wcm')"
                            class="px-4 py-2 rounded-lg border transition
                            text-sm font-medium bg-[#b31b1b] text-white border-[#b31b1b] shadow cursor-pointer"
                    >
                        WCM Investigator Project Inquiry
                    </button>
                    <button type="button" id="external-tab-btn" onclick="switchTab('external')"
                            class="px-4 py-2 rounded-lg border transition
                            text-sm font-medium bg-white text-[#b31b1b] border-gray-300 hover:bg-red-50 cursor-pointer">
                        External Collaboration Project Inquiry
                    </button>
                </div>
            </div>

            {# WCM Investigator Form #}
            {#border caused by class 'tab-content'#}
            <form id="wcm-form"
                  class="tab-content space-y-5 bg-white p-4 rounded-xl border border-gray-200 shadow-sm"
                  method="post"
                  action="{{ path('ctp_new-project-inquiry') }}"
                  style="border: none; display: block;"
            >
                <input type="hidden" name="_token" value="{{ csrf_token('ctp_new_project_inquiry_submit') }}">
                <input type="hidden" name="inquiryType" value="wcm">

                <section class="grid gap-3 md:w-1/2">
                    <div class="grid gap-1">
                        <label class="text-sm text-gray-700">Date <span class="text-red-600">*</span></label>
                        <input type="date" name="inquiryDate" required class="rounded-xl border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#b31b1b]/20 focus:border-[#b31b1b]" value="{{ app.request.request.get('inquiryDate')|default('') }}"/>
                    </div>
                </section>

                <hr class="border-gray-200">

                <section class="grid gap-3 md:grid-cols-2">
                    <div class="grid gap-1">
                        <label class="text-sm text-gray-700">Project Title <span class="text-red-600">*</span></label>
                        <input name="projectTitle" required class="rounded-xl border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#b31b1b]/20 focus:border-[#b31b1b]" placeholder="e.g., Glioblastoma Tissue Microarrays" value="{{ app.request.request.get('projectTitle')|default('') }}"/>
                    </div>
                    <div class="grid gap-1">
                        <label class="text-sm text-gray-700">Principal Investigator <span class="text-red-600">*</span></label>
                        <input name="principalInvestigator" required class="rounded-xl border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#b31b1b]/20 focus:border-[#b31b1b]" placeholder="PI name" value="{{ app.request.request.get('principalInvestigator')|default('') }}"/>
                    </div>
                </section>

                <section class="grid gap-3 md:grid-cols-2">
                    <div class="grid gap-1">
                        <label class="text-sm text-gray-700">Department <span class="text-red-600">*</span></label>
                        <input name="department" required class="rounded-xl border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#b31b1b]/20 focus:border-[#b31b1b]" placeholder="e.g. Pathology and Laboratory Medicine" value="{{ app.request.request.get('department')|default('') }}"/>
                    </div>
                    <div class="grid gap-1">
                        <label class="text-sm text-gray-700">Phone</label>
                        <input type="tel" name="phone" class="rounded-xl border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#b31b1b]/20 focus:border-[#b31b1b]" placeholder="(###) ###-####" value="{{ app.request.request.get('phone')|default('') }}"/>
                    </div>
                </section>

                <section class="grid gap-3">
                    <div class="grid gap-1">
                        <label class="text-sm text-gray-700">Contact Name <span class="text-red-600">*</span></label>
                        <input name="contactName" required class="rounded-xl border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#b31b1b]/20 focus:border-[#b31b1b]" placeholder="e.g., John Doe" value="{{ app.request.request.get('contactName')|default('') }}"/>
                    </div>
                    <div class="grid gap-1">
                        <label class="text-sm text-gray-700">Contact Email Address <span class="text-red-600">*</span></label>
                        <input type="email" name="contactEmail" required class="rounded-xl border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#b31b1b]/20 focus:border-[#b31b1b]" placeholder="e.g. jod2034@med.cornell.edu" value="{{ app.request.request.get('contactEmail')|default('') }}"/>
                    </div>
                </section>

                <section class="grid gap-3">
                    <div class="grid gap-1">
                        <label class="text-sm text-gray-700">Background <span class="text-red-600">*</span></label>
                        <textarea name="background" required class="rounded-xl border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#b31b1b]/20 focus:border-[#b31b1b] resize-none" rows="5" placeholder="Provide background information on the project...">{{ app.request.request.get('background')|default('') }}</textarea>
                    </div>
                </section>

                <section class="grid gap-3">
                    <div class="grid gap-1">
                        <label class="text-sm text-gray-700">Experimental Plan Summary <span class="text-red-600">*</span></label>
                        <textarea name="experimentalPlanSummary" required class="rounded-xl border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#b31b1b]/20 focus:border-[#b31b1b] resize-none" rows="5" placeholder="Summarize the experimental plan and methods...">{{ app.request.request.get('experimentalPlanSummary')|default('') }}</textarea>
                    </div>
                </section>

                <section class="grid gap-3">
                    <div class="grid gap-1">
                        <label class="text-sm text-gray-700">Funding Source</label>
                        <textarea name="fundingSource" class="rounded-xl border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#b31b1b]/20 focus:border-[#b31b1b] resize-none" rows="3" placeholder="List funding sources (if applicable)...">{{ app.request.request.get('fundingSource')|default('') }}</textarea>
                    </div>
                </section>

                <div class="flex items-center gap-3">
                    <button type="submit" class="rounded-xl px-4 py-2 text-white transition bg-[#b31b1b] hover:bg-[#a01515]">
                        Submit
                    </button>
                </div>

            </form>

            {# External Collaboration Form (initially hidden) #}
            <form id="external-form"
                  class="tab-content space-y-5 bg-white p-4 rounded-xl border border-gray-200 shadow-sm"
                  method="post"
                  action="{{ path('ctp_new-project-inquiry') }}"
                  style="border: none; display: none;"
            >
                <input type="hidden" name="_token" value="{{ csrf_token('ctp_new_project_inquiry_submit') }}">
                <input type="hidden" name="inquiryType" value="external">

                <section class="grid gap-3 md:w-1/2">
                    <div class="grid gap-1">
                        <label class="text-sm text-gray-700">Date <span class="text-red-600">*</span></label>
                        <input type="date" name="inquiryDate" required class="rounded-xl border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#b31b1b]/20 focus:border-[#b31b1b]" value="{{ app.request.request.get('inquiryDate')|default('') }}"/>
                    </div>
                </section>

                <hr class="border-gray-200">

                {#<section class="grid gap-3 md:grid-cols-2">#}
                    {#<div class="grid gap-1">#}
                        {#<label class="text-sm text-gray-700">Project Title <span class="text-red-600">*</span></label>#}
                        {#<input class="rounded-xl border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#b31b1b]/20 focus:border-[#b31b1b]" placeholder="e.g., Glioblastoma Tissue Microarrays" value=""/>#}
                    {#</div>#}
                    {#<div class="grid gap-1">#}
                        {#<label class="text-sm text-gray-700">Principal Investigator <span class="text-red-600">*</span></label>#}
                        {#<input class="rounded-xl border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#b31b1b]/20 focus:border-[#b31b1b]" placeholder="PI name" value=""/>#}
                    {#</div>#}
                {#</section>#}
                {#<hr class="border-gray-200">#}

                {#<hr class="border-gray-200">#}

                <section class="grid gap-3">
                    <div class="grid gap-1">
                        <label class="text-sm text-gray-700">External Collaborator Contact Name <span class="text-red-600">*</span></label>
                        <input name="externalContactName" required class="rounded-xl border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#b31b1b]/20 focus:border-[#b31b1b]" placeholder="e.g., John Doe" value="{{ app.request.request.get('externalContactName')|default('') }}"/>
                    </div>
                    <div class="grid gap-1">
                        <label class="text-sm text-gray-700"> ExternalContact Email <span class="text-red-600">*</span></label>
                        <input type="email" name="externalContactEmail" required class="rounded-xl border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#b31b1b]/20 focus:border-[#b31b1b]" placeholder="collaborator@institution.edu" value="{{ app.request.request.get('externalContactEmail')|default('') }}"/>
                    </div>
                </section>

                <section class="grid gap-3 md:grid-cols-2">
                    <div class="grid gap-1 md:col-span-2">
                        <label class="text-sm text-gray-700">Institution<span class="text-red-600">*</span></label>
                        <input name="externalInstitution" required class="rounded-xl border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#b31b1b]/20 focus:border-[#b31b1b]" placeholder="Collaborating institution" value="{{ app.request.request.get('externalInstitution')|default('') }}"/>
                    </div>
                    <div class="grid gap-1">
                        <label class="text-sm text-gray-700">Contact Phone Number (optional)</label>
                        <input type="tel" name="externalPhone" class="rounded-xl border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#b31b1b]/20 focus:border-[#b31b1b]" placeholder="(###) ###-####" value="{{ app.request.request.get('externalPhone')|default('') }}"/>
                    </div>
                </section>

                <section class="grid gap-3">
                    <div class="grid gap-1">
                        <label class="text-sm text-gray-700">Background <span class="text-red-600">*</span></label>
                        <textarea name="background" required class="rounded-xl border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#b31b1b]/20 focus:border-[#b31b1b] resize-none" rows="5" placeholder="Provide background information on the project...">{{ app.request.request.get('background')|default('') }}</textarea>
                    </div>
                </section>

                <section class="grid gap-3">
                    <div class="grid gap-1">
                        <label class="text-sm text-gray-700">Experimental Plan Summary <span class="text-red-600">*</span></label>
                        <textarea name="experimentalPlanSummary" required class="rounded-xl border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#b31b1b]/20 focus:border-[#b31b1b] resize-none" rows="5" placeholder="Summarize the experimental plan and methods...">{{ app.request.request.get('experimentalPlanSummary')|default('') }}</textarea>
                    </div>
                </section>

                {#<section class="grid gap-3">#}
                    {#<div class="grid gap-1">#}
                        {#<label class="text-sm text-gray-700">Funding Source</label>#}
                        {#<textarea class="rounded-xl border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#b31b1b]/20 focus:border-[#b31b1b] resize-none" rows="3" placeholder="List funding sources (if applicable)..."></textarea>#}
                    {#</div>#}
                {#</section>#}

                <div class="flex items-center gap-3">
                    <button type="submit" class="rounded-xl px-4 py-2 text-white transition bg-[#b31b1b] hover:bg-[#a01515]">
                        Submit
                    </button>
                </div>

            </form>

        </main>

    </main>

{% endblock %}

