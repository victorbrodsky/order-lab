{% extends "AppCtpBundle/Default/simple_base.html.twig" %}

{% block title %}
    People - Center for Translational Pathology
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="/orderassets/AppCtpBundle/ctp_site/localhost_3000/_next/static/chunks/src_app_globals_0p2ml0n.css">
    <link rel="icon" href="/orderassets/AppCtpBundle/ctp_site/localhost_3000/faviconbcf9.ico" sizes="256x256" type="image/x-icon">
    <style>
        :root {
            --wcm-red: #b31b1b;
            --wcm-gold: #ffc72c;
            --wcm-orange: #ff6a00;
            --bg: #f9fafb;
            --ink: #1f2937;
        }
        .text-wcm-red { color: var(--wcm-red); }
        .text-wcm-ink { color: var(--ink); }
        .bg-wcm-red { background-color: var(--wcm-red); }
        .bg-wcm-red\/90 { background-color: rgba(179, 27, 27, 0.9); }
        .hover\:bg-wcm-red\/90:hover { background-color: rgba(179, 27, 27, 0.9); }
        .focus-visible\:ring-wcm-red:focus-visible { --tw-ring-color: var(--wcm-red); }
        .backdrop-blur-sm { backdrop-filter: blur(4px); }
    </style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="/orderassets/AppCtpBundle/ctp_site/localhost_3000/_next/static/chunks/node_modules_next_dist_build_polyfills_polyfill-nomodule.js" nomodule></script>
{% endblock %}

