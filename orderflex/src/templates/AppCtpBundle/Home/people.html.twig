    {% set effectivePeoplePageContent = peoplePageContent is defined and peoplePageContent ? peoplePageContent : defaultPeoplePageContent %}

    {% if is_granted('ROLE_CTP_ADMIN') and isEditMode is defined and isEditMode %}
        <div class="mx-auto max-w-6xl px-6 py-6">
            <h2 class="text-xl font-semibold text-wcm-red">Edit People Page Content</h2>
            <p class="mt-2 text-sm text-gray-700">Update the page HTML below. Click Save to publish changes.</p>

            <form method="post" action="{{ path('ctp_people') }}" class="mt-4">
                <input type="hidden" name="_token" value="{{ csrf_token('ctp_people_page_content') }}">
                <input type="hidden" name="editMode" value="1">
                <textarea id="ctp-people-page-content" name="pageContent" class="form-control" style="min-height: 520px; font-family: monospace;">{{ effectivePeoplePageContent|e }}</textarea>

                <div class="mt-4 flex items-center gap-3">
                    <button type="submit" class="inline-flex rounded-md bg-wcm-red px-4 py-2 text-white font-medium shadow hover:bg-wcm-red/90 transition">Save</button>
                    <a href="{{ path('ctp_people') }}" class="inline-flex rounded-md border border-gray-300 px-4 py-2 text-gray-700 font-medium hover:bg-gray-100 transition">Cancel</a>
                </div>
            </form>
        </div>
    {% else %}
        {{ effectivePeoplePageContent|raw }}
    {% endif %}

