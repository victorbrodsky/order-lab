<script>
function selectRequestType(button, type) {
    // Remove active class from all buttons
    const buttons = document.querySelectorAll('.btn');
    buttons.forEach(btn => {
        btn.classList.remove('active');
        btn.classList.add('btn-secondary');
    });
    
    // Add active class to clicked button
    button.classList.add('active');
    button.classList.remove('btn-secondary');
    
    // Hide all forms
    document.getElementById('wcm-form').style.display = 'none';
    document.getElementById('ctp-form').style.display = 'none';
    document.getElementById('conference-form').style.display = 'none';
    
    // Show selected form
    if (type === 'wcm') {
        document.getElementById('wcm-form').style.display = 'block';
    } else if (type === 'ctp') {
        document.getElementById('ctp-form').style.display = 'block';
    } else if (type === 'conference') {
        document.getElementById('conference-form').style.display = 'block';
    }
}

function updateCharCount(textareaId, counterId, maxWords) {
    const textarea = document.getElementById(textareaId);
    const counter = document.getElementById(counterId);
    const text = textarea.value.trim();
    const words = text === '' ? 0 : text.split(/\s+/).length;
    counter.textContent = `(${words}/${maxWords})`;
    
    if (words > maxWords) {
        counter.style.color = '#dc2626';
    } else {
        counter.style.color = '#6b7280';
    }
}

// Handle form submissions
document.getElementById('wcm-form').addEventListener('submit', function(e) {
    e.preventDefault();
    validateAndSubmitForm(this, 'WCM Investigator Project Request');
});

document.getElementById('ctp-form').addEventListener('submit', function(e) {
    e.preventDefault();
    validateAndSubmitForm(this, 'CTP Mini-Grant Application');
});

document.getElementById('conference-form').addEventListener('submit', function(e) {
    e.preventDefault();
    validateAndSubmitForm(this, 'Conference Project Request');
});

function validateAndSubmitForm(form, formType) {
    // Validate required fields
    const requiredFields = form.querySelectorAll('input[required], textarea[required], select[required]');
    let isValid = true;
    
    requiredFields.forEach(field => {
        if (!field.value.trim()) {
            isValid = false;
            field.style.borderColor = '#dc2626';
        } else {
            field.style.borderColor = '';
        }
    });
    
    // Check for required fields that don't have required attribute but are marked with *
    const markedRequired = form.querySelectorAll('span.text-red-600');
    markedRequired.forEach(span => {
        const label = span.parentElement;
        const input = form.querySelector(`#${label.getAttribute('for')}`) || 
                     form.querySelector(`[placeholder="${label.textContent.replace('*', '').trim()}"]`) ||
                     label.nextElementSibling;
        if (input && !input.value.trim()) {
            isValid = false;
            input.style.borderColor = '#dc2626';
        }
    });
    
    if (!isValid) {
        alert(`Please fill in all required fields marked with * for ${formType}`);
        return;
    }
    
    // Here you would typically send the form data to your backend
    alert(`${formType} submitted successfully! You will receive a confirmation email shortly.`);
    
    // Reset form
    form.reset();
    
    // Reset all character counters
    const counters = form.querySelectorAll('.char-counter');
    counters.forEach(counter => {
        const maxWords = counter.textContent.match(/\d+/);
        if (maxWords) {
            counter.textContent = `(0/${maxWords[0]})`;
        }
    });
}
</script>
