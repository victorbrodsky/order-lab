            </div>
            
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 border-b border-gray-200 pb-3">
                <div>
                    <h2 class="text-base font-medium text-gray-700">Request Type</h2>
                    <p class="text-xs text-gray-500">Select the type of project request.</p>
                </div>
                <div class="flex flex-wrap gap-2">
                    <button type="button" class="btn active" onclick="selectRequestType(this, 'wcm')">WCM Investigator Project Request</button>
                    <button type="button" class="btn btn-secondary" onclick="selectRequestType(this, 'ctp')">CTP Mini-Grant Application</button>
                    <button type="button" class="btn btn-secondary" onclick="selectRequestType(this, 'conference')">Conference Project Request (USCAP / AMP / AANP)</button>
                </div>
            </div>
            
            <!-- WCM Investigator Project Request Form -->
