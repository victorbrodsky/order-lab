                <section class="grid gap-3 md:w-1/2">
                    <div class="grid gap-1">
                        <label class="text-sm text-gray-700">Date <span class="text-red-600">*</span></label>
                        <input type="date" class="form-input" value=""/>
                    </div>
                </section>

                <br>
                <hr class="border-gray-200"/>
                
                <section class="grid gap-3 md:grid-cols-2">
                    <div class="grid gap-1 md:col-span-2">
                        <label class="text-sm text-gray-700">Project Title <span class="text-red-600">*</span></label>
                        <input class="form-input" placeholder="e.g., Glioblastoma Tissue Microarray Development" value=""/>
                    </div>
                    
                    <div class="grid gap-1">
                        <label class="text-sm text-gray-700">Principal Investigator <span class="text-red-600">*</span></label>
                        <input class="form-input" placeholder="PI name" value=""/>
                    </div>
                    
                    <div class="grid gap-1">
                        <label class="text-sm text-gray-700">Department <span class="text-red-600">*</span></label>
                        <input class="form-input" placeholder="e.g. Medicine" value=""/>
                    </div>
                    
