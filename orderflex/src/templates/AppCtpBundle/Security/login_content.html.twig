{% import "AppUserdirectoryBundle/Default/usermacros.html.twig" as usermacros %}

<div class="min-h-screen bg-gray-50 flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md">

        {{ usermacros.nonLiveSiteWarning() }}
        {{ usermacros.browserCheck() }}

        {% if messageToUsers is defined and messageToUsers %}
            <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6 text-center text-red-700">
                {{ messageToUsers|raw }}
            </div>
        {% endif %}

        {% if globalNoteOnAllLoginPage is defined and globalNoteOnAllLoginPage %}
            <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6 text-center text-red-700">
                {{ globalNoteOnAllLoginPage|raw }}
            </div>
        {% endif %}

        {% for flashMessage in app.flashes('notice') %}
            <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6 text-center text-blue-700">
                {{ flashMessage|raw }}
            </div>
        {% endfor %}

        {% for flashMessage in app.flashes('warning') %}
            <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-6 text-center text-yellow-700">
                {{ flashMessage|raw }}
            </div>
        {% endfor %}

        {% for flashMessage in app.flashes('pnotify') %}
            <input type="hidden" id="pnotify-notice" value="{{ flashMessage|raw }}" />
        {% endfor %}
        {% for flashMessage in app.flashes('pnotify-error') %}
            <input type="hidden" id="pnotify-notice" class="pnotify-notice-error" value="{{ flashMessage|raw }}" />
        {% endfor %}
        {% for flashMessage in app.flashes('pnotify-success') %}
            <input type="hidden" id="pnotify-notice" class="pnotify-notice-success" value="{{ flashMessage|raw }}" />
        {% endfor %}

        {% if error is not defined %}
            {% set error = '' %}
        {% endif %}

        {% if last_username is not defined %}
            {% set last_username = '' %}
        {% endif %}

        {% if error %}
            <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6 text-center text-red-700">
                There was an error with your User Name/Password combination. Please try again.
            </div>
        {% endif %}

        <input type="hidden" name="display_height" id="display_height" value="" />
        <input type="hidden" name="display_width" id="display_width" value="" />
        <input type="hidden" name="sitename" id="sitename" value={{ sitename }} />
        <input type="hidden" name="lastRoute" id="lastRoute" value={{ lastRoute }} />
        <input type="hidden" name="samlenabled" id="samlenabled" value={{ samlenabled }} />

{% if user_security_utility.allowSiteLogin(sitename) %}
    {# Login Form Card - Path2Path Dashboard Access #}
    <div class="bg-white rounded-2xl border border-gray-200 shadow-lg p-8">
        <div class="mb-6">
            <h1 class="text-2xl font-bold text-[#b31b1b] mb-2">Path2Path Dashboard Access</h1>
            <p class="text-gray-600 text-sm">Enter your WCM Pathology credentials to access internal CTP tools.</p>
        </div>

        <form id="login-form" method="post" class="space-y-5">

            {# Hidden username field #}
            <input type="text"
                   id="username"
                   name="_username"
                   value="{{ last_username }}"
                   placeholder="Username Hidden" style="display:none;">

            {# Account Type Select #}
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Account Type</label>
                <select id="usernametypeid_show" name="_usernametype" class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#b31b1b]/20 focus:border-[#b31b1b] transition-colors bg-white">
                    {% for usernametype in usernametypes %}
                        {% if user_type is defined and usernametype.name == user_type %}
                            {% set selected = 'selected="selected"' %}
                        {% else %}
                            {% set selected = '' %}
                        {% endif %}
                        <option value="{{ usernametype.abbreviation }}" {{ selected }}>{{ usernametype.name }}</option>
                    {% endfor %}
                </select>
            </div>

            {# Display Username #}
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                    Username <span class="text-[#b31b1b]">*</span>
                </label>
                <input type="text"
                       id="display-username"
                       name="_display-username"
                       value="{{ last_username }}"
                       class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#b31b1b]/20 focus:border-[#b31b1b] transition-colors"
                       placeholder="netid or email"
                       autocomplete="username">
            </div>

            {# Password #}
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                    Password <span class="text-[#b31b1b]">*</span>
                </label>
                <input type="password"
                       id="password"
                       name="_password"
                       class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#b31b1b]/20 focus:border-[#b31b1b] transition-colors"
                       placeholder="••••••••"
                       autocomplete="current-password">
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            <input type="hidden" name="_sitename" id="sitename" value="{{ sitename }}" />

            <div id="message" type="hidden"></div>

            <button class="w-full bg-[#b31b1b] text-white font-medium py-3 px-6 rounded-full hover:bg-red-800 transition-colors shadow-md" type="submit">
                Enter Dashboard
            </button>

        </form>

        <div class="mt-6 pt-6 border-t border-gray-100">
            <p class="text-xs text-gray-500 leading-relaxed">
                For demo purposes, any credentials will proceed. Enterprise authentication and fine-grained authorization will be implemented by institutional IT before production deployment.
            </p>
        </div>

        <div class="mt-4 text-center text-sm text-gray-500 hidden">
            <div id="login-instruction" style="display: none;">
                <p>
                    {% set loginInstruction = user_security_utility.getSiteSettingParameter('loginInstruction') %}
                    {% if loginInstruction and loginInstruction != -1 %}
                        {{ loginInstruction|raw }}
                    {% else %}
                        Please use your
                        <a href="https://its.weill.cornell.edu/services/accounts-and-access/center-wide-id" class="text-[#b31b1b] hover:underline">CWID</a>
                        {% if title == "Scan Orders" %}
                            or your
                            <a href="http://c.med.cornell.edu/" class="text-[#b31b1b] hover:underline">External Authentication</a> account
                        {% endif %}
                        to log in.
                    {% endif %}
                </p>
            </div>

            {{ user_security_utility.getLoginFooter(sitename)|raw }}
        </div>
    </div>
{% else %}
    <div class="bg-white rounded-2xl border border-gray-200 shadow-lg p-8 text-center">
        <p class="text-gray-600">This site is being prepared for go-live. Please return once it launches.</p>
    </div>
{% endif %}

    </div>
</div>

<script language="Javascript">
    <!--
        document.getElementById("display_height").value = screen.height;
        document.getElementById("display_width").value = screen.width;
    //-->
</script>