{% import "AppFellAppBundle/Default/fellappmacros.html.twig" as fellappmacros %}

{#Institutions/Programs#}

{% if collapsein is not defined %}
    {% set collapsein = "in" %}
{% endif %}

<!-- Fellowship Type -->
<div class="panel panel-info">
    <div class="panel-heading">
        <h4 class="panel-title">
            <a data-toggle="collapse" href="#fellowship-institution">
                Institution
            </a>
        </h4>
    </div>
    <div id="fellowship-institution" class="panel-collapse collapse {{ collapsein }}">
        <div class="panel-body">

            {# Yellow warning well for invalid/not accepting program #}
            {% if invalidProgram is defined and invalidProgram and notAcceptMessage is defined and notAcceptMessage %}
                <div id="not-accept-message-well" class="alert alert-warning">
                    {#{{ notAcceptMessage|replace({'[[LOCAL INSTITUTION NAME]]': invalidProgram})|raw }}#}
                    {{ notAcceptMessage|raw }}
                </div>
            {% endif %}

            <div class="well">
                <div class="row">
                    <div class="col-xs-12">

                        {{ form_row(form.institution) }}

                    </div>
                </div> <!-- row -->
            </div> {#well#}

        </div> <!-- panel-body -->
    </div> <!-- panel-collapse -->
</div> <!-- panel panel-info -->

{% if invalidProgram is defined and invalidProgram %}
<script>
    // Wait for jQuery to be available
    document.addEventListener('DOMContentLoaded', function() {
        if (typeof jQuery !== 'undefined') {
            jQuery(function($) {
                // Hide the not-accept message when institution or fellowship specialty changes
                $('#oleg_fellappbundle_fellowshipapplication_institution, #oleg_fellappbundle_fellowshipapplication_fellowshipSubspecialty, #oleg_fellappbundle_fellowshipapplication_globalFellowshipSpecialty').on('change', function() {
                    $('#not-accept-message-well').fadeOut();
                });
            });
        }
    });
</script>
{% endif %}
