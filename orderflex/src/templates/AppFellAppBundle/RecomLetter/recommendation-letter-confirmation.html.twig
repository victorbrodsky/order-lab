{% extends "AppFellAppBundle/Default/base.html.twig" %}

{% block title %}
    Recommendation Letter Confirmation
{% endblock %}

{% block header %}
{% endblock %}

{% block content %}

    <input type="hidden" id="disableIdleTimeout" value="1" />

    <div class="container">
        <div class="row">
            <div class="col-md-8 col-md-offset-2">
                <div class="panel panel-success" style="margin-top: 40px;">
                    <div class="panel-heading text-center">
                        <h3 class="panel-title">
                            <span class="glyphicon glyphicon-ok-circle" aria-hidden="true"></span>
                            Recommendation Letter Received
                        </h3>
                    </div>
                    <div class="panel-body text-center">
                        <h4 class="text-success">Thank you!</h4>
                        <p class="lead">
                            {% if note1 is defined %}
                                {{ note1 }}
                            {% else %}
                                Your recommendation letter has been successfully submitted.
                            {% endif %}
                        </p>
                        <hr>
                        <p>
                            {% if note2 is defined %}
                                {{ note2 }}
                            {% else %}
                                The fellowship application system has received your letter of recommendation.
                                The applicant and the fellowship program will be notified accordingly.
                            {% endif %}
                        </p>
                        <p class="text-muted">
                            If you have any questions, please contact the fellowship program coordinator.
                        </p>
                    </div>
                    <div class="panel-footer text-center">
                        {#<a href="{{ path('fellapp_home') }}" class="btn btn-primary">#}
                            {#<span class="glyphicon glyphicon-home" aria-hidden="true"></span>#}
                            {#Return to Fellowship Applications#}
                        {#</a>#}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
