{% extends "AppCtpBundle/Default/base.html.twig" %}

{% block title %}
    {{ title|default('Prostate Cancer Research Data Explorer') }}
{% endblock %}

{% block content_ctp %}
    <main class="min-h-screen bg-gray-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            {# Page Header #}
            <div class="mb-8">
                <h1 class="text-3xl font-bold text-gray-900 mb-2">Prostate Cancer Research Data Explorer</h1>
                <p class="text-gray-600">SPORE Dashboard - Comprehensive prostate cancer research data management</p>
            </div>

            {# Quick Actions #}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
                <a href="{{ path('spore_patients') }}" class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm hover:shadow-md transition hover:border-wcm-red">
                    <div class="flex items-center gap-3 mb-3">
                        <div class="bg-wcm-red/10 p-2 rounded-lg">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#b31b1b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6">
                                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                                <circle cx="9" cy="7" r="4"/>
                                <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
                                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                            </svg>
                        </div>
                        <h3 class="font-semibold text-gray-800">Patient Browser</h3>
                    </div>
                    <p class="text-sm text-gray-600">Search and filter patients</p>
                </a>

                <a href="{{ path('spore_specimens') }}" class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm hover:shadow-md transition hover:border-wcm-red">
                    <div class="flex items-center gap-3 mb-3">
                        <div class="bg-wcm-red/10 p-2 rounded-lg">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#b31b1b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6">
                                <path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/>
                                <path d="m22 17.65-8.58 3.91a2 2 0 0 1-1.66 0L2.6 17.64"/>
                                <path d="m22 12.65-8.58 3.91a2 2 0 0 1-1.66 0L2.6 12.64"/>
                            </svg>
                        </div>
                        <h3 class="font-semibold text-gray-800">Specimen Lookup</h3>
                    </div>
                    <p class="text-sm text-gray-600">Find cases by accession</p>
                </a>

                <a href="{{ path('spore_biomarkers') }}" class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm hover:shadow-md transition hover:border-wcm-red">
                    <div class="flex items-center gap-3 mb-3">
                        <div class="bg-wcm-red/10 p-2 rounded-lg">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#b31b1b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6">
                                <path d="M10 2v7.31"/>
                                <path d="M14 9.3V1.99"/>
                                <path d="M8.5 2h7"/>
                                <path d="M14 9.3a6.5 6.5 0 1 1-4 0"/>
                                <path d="M5.52 16h12.96"/>
                            </svg>
                        </div>
                        <h3 class="font-semibold text-gray-800">Biomarker Summary</h3>
                    </div>
                    <p class="text-sm text-gray-600">ERG, PTEN, SPOP, SPINK1</p>
                </a>

                <a href="{{ path('spore_outcomes') }}" class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm hover:shadow-md transition hover:border-wcm-red">
                    <div class="flex items-center gap-3 mb-3">
                        <div class="bg-wcm-red/10 p-2 rounded-lg">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#b31b1b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6">
                                <path d="M3 3v16a2 2 0 0 0 2 2h16"/>
                                <path d="m19 9-5 5-4-4-3 3"/>
                            </svg>
                        </div>
                        <h3 class="font-semibold text-gray-800">Outcomes Explorer</h3>
                    </div>
                    <p class="text-sm text-gray-600">Recurrence & survival</p>
                </a>
            </div>

            {# Statistics Cards #}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
                <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
                    <div class="flex items-center gap-3 mb-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#b31b1b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                            <circle cx="9" cy="7" r="4"/>
                        </svg>
                        <span class="text-sm text-gray-600">Patients</span>
                    </div>
                    <p class="text-3xl font-bold text-gray-900">{{ dashboard.totalPatients|default(0)|number_format }}</p>
                </div>

                <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
                    <div class="flex items-center gap-3 mb-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#b31b1b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
                            <path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/>
                        </svg>
                        <span class="text-sm text-gray-600">Specimens</span>
                    </div>
                    <p class="text-3xl font-bold text-gray-900">{{ dashboard.totalSpecimens|default(0)|number_format }}</p>
                </div>

                <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
                    <div class="flex items-center gap-3 mb-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#b31b1b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
                            <rect width="18" height="18" x="3" y="3" rx="2"/>
                            <path d="M3 9h18"/>
                            <path d="M9 21V9"/>
                        </svg>
                        <span class="text-sm text-gray-600">Blocks</span>
                    </div>
                    <p class="text-3xl font-bold text-gray-900">{{ dashboard.totalBlocks|default(0)|number_format }}</p>
                </div>

                <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
                    <div class="flex items-center gap-3 mb-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#b31b1b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
                            <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
                            <circle cx="9" cy="9" r="2"/>
                            <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
                        </svg>
                        <span class="text-sm text-gray-600">Slides</span>
                    </div>
                    <p class="text-3xl font-bold text-gray-900">{{ dashboard.totalSlides|default(0)|number_format }}</p>
                </div>

                <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
                    <div class="flex items-center gap-3 mb-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#b31b1b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
                            <circle cx="12" cy="12" r="10"/>
                            <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/>
                            <path d="M2 12h20"/>
                        </svg>
                        <span class="text-sm text-gray-600">TMA Cores</span>
                    </div>
                    <p class="text-3xl font-bold text-gray-900">{{ dashboard.totalTMACores|default(0)|number_format }}</p>
                </div>
            </div>

            {# Main Content Grid #}
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
                {# Gleason Score Distribution #}
                <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
                    <h3 class="text-lg font-semibold text-gray-800 mb-4">Gleason Score Distribution</h3>
                    {% if dashboard.gleasonData is defined and dashboard.gleasonData %}
                        <div class="space-y-3">
                            {% for item in dashboard.gleasonData %}
                                <div>
                                    <div class="flex justify-between text-sm mb-1">
                                        <span class="text-gray-600">{{ item.score }}</span>
                                        <span class="font-medium">{{ item.count }}</span>
                                    </div>
                                    <div class="flex h-2 rounded-full overflow-hidden bg-gray-100">
                                        <div class="bg-wcm-red" style="width: {{ item.percentage }}%"></div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="text-gray-500 text-center py-8">No Gleason score data available</p>
                    {% endif %}
                </div>

                {# Biomarker Analysis #}
                <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
                    <h3 class="text-lg font-semibold text-gray-800 mb-4">Biomarker Analysis</h3>
                    {% if dashboard.biomarkerData is defined and dashboard.biomarkerData %}
                        <div class="grid grid-cols-2 gap-4">
                            {% for marker in dashboard.biomarkerData %}
                                <div class="bg-gray-50 rounded-lg p-4">
                                    <h4 class="font-medium text-gray-800 mb-2">{{ marker.name }}</h4>
                                    <div class="flex gap-2 text-xs">
                                        <span class="px-2 py-1 bg-green-100 text-green-800 rounded">{{ marker.positive }}% Positive</span>
                                        <span class="px-2 py-1 bg-gray-200 text-gray-700 rounded">{{ marker.negative }}% Negative</span>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="text-gray-500 text-center py-8">No biomarker data available</p>
                    {% endif %}
                </div>
            </div>

            {# Secondary Charts Grid #}
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
                {# Procedure Types #}
                <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
                    <h3 class="text-lg font-semibold text-gray-800 mb-4">Procedure Types</h3>
                    {% if dashboard.procedureTypes is defined and dashboard.procedureTypes %}
                        <div class="space-y-3">
                            {% for procedure in dashboard.procedureTypes %}
                                <div class="flex items-center justify-between">
                                    <span class="text-gray-600">{{ procedure.name }}</span>
                                    <span class="font-medium">{{ procedure.count }}</span>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="text-gray-500 text-center py-8">No procedure data available</p>
                    {% endif %}
                </div>

                {# Race Distribution #}
                <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
                    <h3 class="text-lg font-semibold text-gray-800 mb-4">Race Distribution</h3>
                    {% if dashboard.raceDistribution is defined and dashboard.raceDistribution %}
                        <div class="space-y-3">
                            {% for race in dashboard.raceDistribution %}
                                <div>
                                    <div class="flex justify-between text-sm mb-1">
                                        <span class="text-gray-600">{{ race.name }}</span>
                                        <span class="font-medium">{{ race.percentage }}%</span>
                                    </div>
                                    <div class="flex h-2 rounded-full overflow-hidden bg-gray-100">
                                        <div class="bg-wcm-red" style="width: {{ race.percentage }}%"></div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="text-gray-500 text-center py-8">No race distribution data available</p>
                    {% endif %}
                </div>

                {# Survival Status #}
                <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
                    <h3 class="text-lg font-semibold text-gray-800 mb-4">Survival Status</h3>
                    {% if dashboard.survivalData is defined and dashboard.survivalData %}
                        <div class="space-y-4">
                            {% for status in dashboard.survivalData %}
                                <div class="flex items-center gap-3">
                                    <div class="w-3 h-3 rounded-full {% if status.name == 'Alive' %}bg-green-500{% elseif status.name == 'Deceased' %}bg-red-500{% else %}bg-yellow-500{% endif %}"></div>
                                    <span class="text-gray-600">{{ status.name }}</span>
                                    <span class="font-medium ml-auto">{{ status.count }} ({{ status.percentage }}%)</span>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="text-gray-500 text-center py-8">No survival data available</p>
                    {% endif %}
                </div>
            </div>

            {# Quick Search #}
            <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm mb-8">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">Quick Patient Search</h3>
                <form action="{{ path('spore_patients') }}" method="get" class="flex gap-4">
                    <div class="flex-1 relative">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3 top-1/2 -translate-y-1/2 h-5 w-5 text-gray-400">
                            <circle cx="11" cy="11" r="8"/>
                            <path d="m21 21-4.3-4.3"/>
                        </svg>
                        <input type="text" name="q" placeholder="Search by WCM ID, case number, or patient ID..." 
                               class="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-wcm-red focus:border-wcm-red">
                    </div>
                    <button type="submit" class="px-6 py-3 bg-wcm-red text-white rounded-lg hover:bg-red-700 transition">
                        Search
                    </button>
                </form>
            </div>

            {# Recent Activity #}
            <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-lg font-semibold text-gray-800">Recent Activity</h3>
                    <a href="#" class="text-sm text-wcm-red hover:underline">View All</a>
                </div>
                {% if recentActivity is defined and recentActivity %}
                    <div class="space-y-3">
                        {% for activity in recentActivity %}
                            <div class="flex items-center justify-between py-3 border-b border-gray-100 last:border-0">
                                <div class="flex items-center gap-3">
                                    <div class="bg-gray-100 p-2 rounded-full">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-600">
                                            <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
                                        </svg>
                                    </div>
                                    <div>
                                        <p class="font-medium text-gray-800">{{ activity.description }}</p>
                                        <p class="text-sm text-gray-500">{{ activity.timestamp|date('M d, Y H:i') }}</p>
                                    </div>
                                </div>
                                <span class="px-2 py-1 text-xs rounded-full {% if activity.type == 'new' %}bg-green-100 text-green-800{% elseif activity.type == 'update' %}bg-blue-100 text-blue-800{% else %}bg-gray-100 text-gray-800{% endif %}">
                                    {{ activity.type|capitalize }}
                                </span>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <p class="text-gray-500 text-center py-8">No recent activity</p>
                {% endif %}
            </div>
        </div>
    </main>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
{% endblock %}
