{% extends "AppCtpBundle/Default/base.html.twig" %}

{% block title %}
    Spore - Center for Translational Pathology
{% endblock %}

{% block content_ctp %}
    <main class="min-h-screen bg-[var(--bg)] text-[var(--ink)]">
        <div class="min-h-screen bg-gray-50">
            <header class="border-b border-gray-200 bg-white">
                <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
                    <div>
                        <h1 class="text-xl font-semibold text-[#b31b1b]">You are in Path2Path</h1>
                        <p class="text-xs text-gray-600">Internal CTP apps & research tools</p>
                    </div>
                    <a class="text-xs px-2 py-1 border rounded-md hover:bg-gray-100" href="{{ path('ctp_home') }}">Public Site</a>
                </div>
                <div class="border-t border-gray-100 bg-gray-50/80">
                    <div class="max-w-6xl mx-auto px-4 py-3 flex justify-center">
                        <a class="inline-flex items-center gap-2 rounded-full bg-[#b31b1b] text-white px-4 py-2 text-xs font-medium shadow hover:bg-[#a01515] transition"
                           {#href="{{ path('ctp_dashboard') }}"#}
                           href="{{ path('ctp_applications') }}"
                        >
                            <span class="flex items-center justify-center rounded-full bg-white/15 p-1.5">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-house h-4 w-4" aria-hidden="true">
                                    <path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"></path>
                                    <path d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                                </svg>
                            </span>
                            <span>Back to Dashboard</span>
                        </a>
                    </div>
                </div>
            </header>
            
            <main class="max-w-6xl mx-auto px-4 py-6">
                <div class="space-y-6">
                    <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
                        <h2 class="text-xl font-semibold text-[#b31b1b] mb-4">Spore Applications</h2>
                        <p class="text-gray-600 mb-6">Manage and track your spore research projects and applications.</p>
                        
                        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
                            <div class="bg-gray-50 rounded-lg p-4 border border-gray-200 hover:bg-gray-100 transition cursor-pointer">
                                <h3 class="font-medium text-gray-800 mb-2">New Application</h3>
                                <p class="text-sm text-gray-600">Submit a new spore research application</p>
                            </div>
                            <div class="bg-gray-50 rounded-lg p-4 border border-gray-200 hover:bg-gray-100 transition cursor-pointer">
                                <h3 class="font-medium text-gray-800 mb-2">Track Status</h3>
                                <p class="text-sm text-gray-600">Check application status and updates</p>
                            </div>
                            <div class="bg-gray-50 rounded-lg p-4 border border-gray-200 hover:bg-gray-100 transition cursor-pointer">
                                <h3 class="font-medium text-gray-800 mb-2">Reports</h3>
                                <p class="text-sm text-gray-600">View detailed reports and analytics</p>
                            </div>
                        </div>
                    </div>
                    
                    <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
                        <h3 class="text-lg font-medium text-gray-800 mb-4">Recent Activity</h3>
                        <div class="space-y-3">
                            <div class="flex items-center justify-between py-3 border-b border-gray-100">
                                <div>
                                    <p class="font-medium text-gray-800">Sample Application #001</p>
                                    <p class="text-sm text-gray-600">Submitted 2 days ago</p>
                                </div>
                                <span class="px-2 py-1 bg-yellow-100 text-yellow-800 text-xs rounded-full">Under Review</span>
                            </div>
                            <div class="flex items-center justify-between py-3 border-b border-gray-100">
                                <div>
                                    <p class="font-medium text-gray-800">Sample Application #002</p>
                                    <p class="text-sm text-gray-600">Submitted 5 days ago</p>
                                </div>
                                <span class="px-2 py-1 bg-green-100 text-green-800 text-xs rounded-full">Approved</span>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </main>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
{% endblock %}
