{% extends "AppCtpBundle/Default/base.html.twig" %}

{% block title %}
    {{ title }} - SPORE
{% endblock %}

{% block content_ctp %}
    <main class="min-h-screen bg-gray-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            {# Page Header #}
            <div class="mb-8">
                <div class="flex items-center gap-4 mb-4">
                    <a href="{{ path('spore_home') }}" class="text-gray-600 hover:text-gray-900">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="m12 19-7-7 7-7"/>
                            <path d="M19 12H5"/>
                        </svg>
                    </a>
                    <h1 class="text-3xl font-bold text-gray-900">Outcomes Explorer</h1>
                </div>
                <p class="text-gray-600">Recurrence and survival analysis for prostate cancer patients</p>
            </div>

            {# Key Metrics #}
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
                <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
                    <div class="flex items-center gap-3 mb-2">
                        <div class="bg-red-100 p-2 rounded-lg">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6">
                                <path d="M3 3v16a2 2 0 0 0 2 2h16"/>
                                <path d="m19 9-5 5-4-4-3 3"/>
                            </svg>
                        </div>
                        <span class="text-sm text-gray-600">Recurrence Rate</span>
                    </div>
                    <p class="text-3xl font-bold text-gray-900">{{ outcomes.recurrenceRate }}%</p>
                    <p class="text-sm text-gray-500 mt-1">Of total patient cohort</p>
                </div>

                <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
                    <div class="flex items-center gap-3 mb-2">
                        <div class="bg-blue-100 p-2 rounded-lg">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6">
                                <circle cx="12" cy="12" r="10"/>
                                <polyline points="12 6 12 12 16 14"/>
                            </svg>
                        </div>
                        <span class="text-sm text-gray-600">Median Follow-up</span>
                    </div>
                    <p class="text-3xl font-bold text-gray-900">{{ outcomes.medianFollowUp }} <span class="text-lg font-normal text-gray-600">months</span></p>
                    <p class="text-sm text-gray-500 mt-1">Since initial diagnosis</p>
                </div>

                <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
                    <div class="flex items-center gap-3 mb-2">
                        <div class="bg-green-100 p-2 rounded-lg">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6">
                                <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
                            </svg>
                        </div>
                        <span class="text-sm text-gray-600">5-Year Survival</span>
                    </div>
                    <p class="text-3xl font-bold text-gray-900">{{ outcomes.fiveYearSurvival }}%</p>
                    <p class="text-sm text-gray-500 mt-1">Overall survival rate</p>
                </div>
            </div>

            {# Survival Analysis Chart Placeholder #}
            <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm mb-8">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">Survival Analysis</h3>
                <div class="h-64 bg-gray-50 rounded-lg flex items-center justify-center border border-dashed border-gray-300">
                    <div class="text-center">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-2 text-gray-400">
                            <path d="M3 3v16a2 2 0 0 0 2 2h16"/>
                            <path d="m19 9-5 5-4-4-3 3"/>
                        </svg>
                        <p class="text-gray-500">Survival curve visualization</p>
                        <p class="text-sm text-gray-400 mt-1">(Implement with Chart.js or similar library)</p>
                    </div>
                </div>
            </div>

            {# Recurrence Analysis #}
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
                    <h3 class="text-lg font-semibold text-gray-800 mb-4">Recurrence by Gleason Score</h3>
                    <div class="space-y-3">
                        <div>
                            <div class="flex justify-between text-sm mb-1">
                                <span class="text-gray-600">6 (3+3)</span>
                                <span class="font-medium">12%</span>
                            </div>
                            <div class="flex h-2 rounded-full overflow-hidden bg-gray-100">
                                <div class="bg-green-500" style="width: 12%"></div>
                            </div>
                        </div>
                        <div>
                            <div class="flex justify-between text-sm mb-1">
                                <span class="text-gray-600">7 (3+4)</span>
                                <span class="font-medium">22%</span>
                            </div>
                            <div class="flex h-2 rounded-full overflow-hidden bg-gray-100">
                                <div class="bg-yellow-500" style="width: 22%"></div>
                            </div>
                        </div>
                        <div>
                            <div class="flex justify-between text-sm mb-1">
                                <span class="text-gray-600">7 (4+3)</span>
                                <span class="font-medium">31%</span>
                            </div>
                            <div class="flex h-2 rounded-full overflow-hidden bg-gray-100">
                                <div class="bg-orange-500" style="width: 31%"></div>
                            </div>
                        </div>
                        <div>
                            <div class="flex justify-between text-sm mb-1">
                                <span class="text-gray-600">8-10</span>
                                <span class="font-medium">45%</span>
                            </div>
                            <div class="flex h-2 rounded-full overflow-hidden bg-gray-100">
                                <div class="bg-red-500" style="width: 45%"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
                    <h3 class="text-lg font-semibold text-gray-800 mb-4">Risk Stratification</h3>
                    <div class="space-y-4">
                        <div class="flex items-center justify-between p-3 bg-green-50 rounded-lg">
                            <div class="flex items-center gap-3">
                                <span class="w-3 h-3 rounded-full bg-green-500"></span>
                                <span class="font-medium text-gray-800">Low Risk</span>
                            </div>
                            <span class="text-green-700 font-bold">523 patients (42%)</span>
                        </div>
                        <div class="flex items-center justify-between p-3 bg-yellow-50 rounded-lg">
                            <div class="flex items-center gap-3">
                                <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
                                <span class="font-medium text-gray-800">Intermediate Risk</span>
                            </div>
                            <span class="text-yellow-700 font-bold">412 patients (33%)</span>
                        </div>
                        <div class="flex items-center justify-between p-3 bg-red-50 rounded-lg">
                            <div class="flex items-center gap-3">
                                <span class="w-3 h-3 rounded-full bg-red-500"></span>
                                <span class="font-medium text-gray-800">High Risk</span>
                            </div>
                            <span class="text-red-700 font-bold">312 patients (25%)</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
{% endblock %}
