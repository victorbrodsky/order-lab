{% extends "AppCtpBundle/Default/base.html.twig" %}

{% block title %}
    {{ title|default('Outcomes Explorer') }} - SPORE
{% endblock %}

{% block content_ctp %}
    <main class="min-h-screen bg-gray-50">
        {# Path2Path Header #}
        <div class="bg-white border-b border-gray-200">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
                <div class="flex items-center justify-between">
                    <div>
                        <h2 class="text-wcm-red font-semibold">You are in Path2Path</h2>
                        <p class="text-xs text-gray-500">Internal CTP apps & research tools</p>
                    </div>
                    <button class="px-3 py-1 text-sm border border-gray-300 rounded text-gray-600">Public Site</button>
                </div>
            </div>
        </div>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
            {# Back to Dashboard Button #}
            <div class="text-center mb-6">
                <a href="{{ path('spore_home') }}" class="inline-flex items-center gap-2 px-4 py-2 bg-wcm-red text-white rounded-lg text-sm font-medium hover:bg-red-700">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                        <polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                    Back to Dashboard
                </a>
            </div>

            {# Page Header #}
            <div class="mb-6">
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2">
                        <a href="{{ path('spore_home') }}" class="text-wcm-red hover:underline">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="m12 19-7-7 7-7"/>
                                <path d="M19 12H5"/>
                            </svg>
                        </a>
                        <h1 class="text-xl font-bold text-wcm-red">Outcomes Explorer</h1>
                    </div>
                    <button class="flex items-center gap-2 px-3 py-1.5 bg-white border border-gray-300 rounded-lg text-sm text-gray-700">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                            <polyline points="7 10 12 15 17 10"/>
                            <line x1="12" x2="12" y1="15" y2="3"/>
                        </svg>
                        Export Report
                    </button>
                </div>
                <p class="text-sm text-gray-500 ml-8">Survival, recurrence, and metastasis analysis</p>
            </div>

            {# Stat Cards #}
            <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-3 mb-6">
                <div class="bg-white rounded-lg border border-gray-200 p-4 shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#b31b1b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mb-2">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                    </svg>
                    <p class="text-2xl font-bold text-gray-900">0</p>
                    <p class="text-xs text-gray-500">Total Patients</p>
                </div>

                <div class="bg-white rounded-lg border border-gray-200 p-4 shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mb-2">
                        <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
                    </svg>
                    <p class="text-2xl font-bold text-gray-900">0</p>
                    <p class="text-xs text-gray-500">Alive</p>
                    <p class="text-xs text-gray-400">NaN%</p>
                </div>

                <div class="bg-white rounded-lg border border-gray-200 p-4 shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mb-2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" x2="12" y1="8" y2="12"/>
                        <line x1="12" x2="12.01" y1="16" y2="16"/>
                    </svg>
                    <p class="text-2xl font-bold text-gray-900">0</p>
                    <p class="text-xs text-gray-500">Deceased</p>
                    <p class="text-xs text-gray-400">NaN%</p>
                </div>

                <div class="bg-white rounded-lg border border-gray-200 p-4 shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mb-2">
                        <path d="M3 3v16a2 2 0 0 0 2 2h16"/>
                        <path d="m19 9-5 5-4-4-3 3"/>
                    </svg>
                    <p class="text-2xl font-bold text-gray-900">0</p>
                    <p class="text-xs text-gray-500">Recurrence</p>
                    <p class="text-xs text-gray-400">NaN%</p>
                </div>

                <div class="bg-white rounded-lg border border-gray-200 p-4 shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mb-2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="2" x2="22" y1="12" y2="12"/>
                    </svg>
                    <p class="text-2xl font-bold text-gray-900">0</p>
                    <p class="text-xs text-gray-500">Metastasis</p>
                    <p class="text-xs text-gray-400">NaN%</p>
                </div>

                <div class="bg-white rounded-lg border border-gray-200 p-4 shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mb-2">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="12 6 12 12 16 14"/>
                    </svg>
                    <p class="text-2xl font-bold text-gray-900">0.0</p>
                    <p class="text-xs text-gray-500">Avg Follow-up</p>
                    <p class="text-xs text-gray-400">years</p>
                </div>

                <div class="bg-white rounded-lg border border-gray-200 p-4 shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mb-2">
                        <circle cx="12" cy="12" r="10"/>
                        <path d="M12 16v-4"/>
                        <path d="M12 8h.01"/>
                    </svg>
                    <p class="text-2xl font-bold text-gray-900">0</p>
                    <p class="text-xs text-gray-500">Unknown Status</p>
                </div>
            </div>

            {# Tabs #}
            <div class="border-b border-gray-200 mb-6">
                <nav class="flex gap-6">
                    <button id="tab-survival" class="px-1 py-2 text-sm font-medium text-wcm-red border-b-2 border-wcm-red" onclick="showTab('survival')">Survival Analysis</button>
                    <button id="tab-recurrence" class="px-1 py-2 text-sm font-medium text-gray-500 hover:text-gray-700" onclick="showTab('recurrence')">Recurrence</button>
                    <button id="tab-metastasis" class="px-1 py-2 text-sm font-medium text-gray-500 hover:text-gray-700" onclick="showTab('metastasis')">Metastasis</button>
                </nav>
            </div>

            {# Content Grid - Survival Analysis #}
            <div id="content-survival" class="tab-content grid grid-cols-1 lg:grid-cols-2 gap-6">
                {# Survival by Gleason Score #}
                <div class="bg-white rounded-lg border border-gray-200 p-6 shadow-sm">
                    <h3 class="text-lg font-semibold text-gray-800 mb-4">Survival by Gleason Score</h3>
                    <div class="space-y-4">
                        <div>
                            <div class="flex justify-between text-sm mb-2">
                                <span class="text-gray-600">Gleason ≤6</span>
                                <span class="text-gray-500">0/0 alive (0.0%)</span>
                            </div>
                            <div class="flex h-2 rounded bg-gray-100 mb-1">
                                <div class="bg-gray-200" style="width: 0%"></div>
                            </div>
                            <div class="flex justify-between text-xs text-gray-400">
                                <span>0 alive</span>
                                <span>0 deceased</span>
                            </div>
                        </div>

                        <div>
                            <div class="flex justify-between text-sm mb-2">
                                <span class="text-gray-600">Gleason 7</span>
                                <span class="text-gray-500">0/0 alive (0.0%)</span>
                            </div>
                            <div class="flex h-2 rounded bg-gray-100 mb-1">
                                <div class="bg-gray-200" style="width: 0%"></div>
                            </div>
                            <div class="flex justify-between text-xs text-gray-400">
                                <span>0 alive</span>
                                <span>0 deceased</span>
                            </div>
                        </div>

                        <div>
                            <div class="flex justify-between text-sm mb-2">
                                <span class="text-gray-600">Gleason 8</span>
                                <span class="text-gray-500">0/0 alive (0.0%)</span>
                            </div>
                            <div class="flex h-2 rounded bg-gray-100 mb-1">
                                <div class="bg-gray-200" style="width: 0%"></div>
                            </div>
                            <div class="flex justify-between text-xs text-gray-400">
                                <span>0 alive</span>
                                <span>0 deceased</span>
                            </div>
                        </div>

                        <div>
                            <div class="flex justify-between text-sm mb-2">
                                <span class="text-gray-600">Gleason 9-10</span>
                                <span class="text-gray-500">0/0 alive (0.0%)</span>
                            </div>
                            <div class="flex h-2 rounded bg-gray-100 mb-1">
                                <div class="bg-gray-200" style="width: 0%"></div>
                            </div>
                            <div class="flex justify-between text-xs text-gray-400">
                                <span>0 alive</span>
                                <span>0 deceased</span>
                            </div>
                        </div>
                    </div>
                </div>

                {# Outcomes by Procedure Type #}
                <div class="bg-white rounded-lg border border-gray-200 p-6 shadow-sm">
                    <h3 class="text-lg font-semibold text-gray-800 mb-4">Outcomes by Procedure Type</h3>
                    <div class="overflow-x-auto">
                        <table class="w-full text-sm">
                            <thead>
                                <tr class="border-b">
                                    <th class="text-left py-2 font-medium text-gray-600">Procedure</th>
                                    <th class="text-left py-2 font-medium text-gray-600">Total</th>
                                    <th class="text-left py-2 font-medium text-gray-600">Recurrence</th>
                                    <th class="text-left py-2 font-medium text-gray-600">Metastasis</th>
                                </tr>
                            </thead>
                            <tbody>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            {# Content Grid - Recurrence #}
            <div id="content-recurrence" class="tab-content grid grid-cols-1 lg:grid-cols-2 gap-6" style="display: none;">
                {# Recurrence by Year #}
                <div class="bg-white rounded-lg border border-gray-200 p-6 shadow-sm">
                    {#<h3 class="text-lg font-semibold text-gray-800 mb-4">#}
                        {#<span class="inline-block bg-gray-100 text-gray-700 text-xs px-2 py-1 rounded mr-2">Recurrence by Year</span>#}
                    {#</h3>#}
                    <h3 class="text-lg font-semibold text-gray-800 mb-4">Recurrence by Year</h3>
                    <div class="h-64 flex items-center justify-center text-gray-400">
                        No recurrence data available
                    </div>
                </div>

                {# Time to Recurrence #}
                <div class="bg-white rounded-lg border border-gray-200 p-6 shadow-sm">
                    <h3 class="text-lg font-semibold text-gray-800 mb-4">Time to Recurrence (from procedure)</h3>
                    <div class="space-y-3">
                        <div class="flex items-center gap-3">
                            <span class="text-sm text-gray-600 w-20">&lt; 1 year</span>
                            <div class="flex-1 h-8 bg-wcm-red rounded" style="width: 0%;"></div>
                            <span class="text-sm text-gray-600 w-8 text-right">0</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="text-sm text-gray-600 w-20">1-2 years</span>
                            <div class="flex-1 h-8 bg-wcm-red rounded" style="width: 0%;"></div>
                            <span class="text-sm text-gray-600 w-8 text-right">0</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="text-sm text-gray-600 w-20">2-3 years</span>
                            <div class="flex-1 h-8 bg-wcm-red rounded" style="width: 0%;"></div>
                            <span class="text-sm text-gray-600 w-8 text-right">0</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="text-sm text-gray-600 w-20">3-5 years</span>
                            <div class="flex-1 h-8 bg-wcm-red rounded" style="width: 0%;"></div>
                            <span class="text-sm text-gray-600 w-8 text-right">0</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="text-sm text-gray-600 w-20">5-10 years</span>
                            <div class="flex-1 h-8 bg-wcm-red rounded" style="width: 0%;"></div>
                            <span class="text-sm text-gray-600 w-8 text-right">0</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="text-sm text-gray-600 w-20">&gt; 10 years</span>
                            <div class="flex-1 h-8 bg-wcm-red rounded" style="width: 0%;"></div>
                            <span class="text-sm text-gray-600 w-8 text-right">0</span>
                        </div>
                    </div>
                    <p class="text-xs text-gray-500 mt-4">Distribution of time from initial procedure to documented recurrence</p>
                </div>
            </div>

            {# Content Grid - Metastasis #}
            <div id="content-metastasis" class="tab-content grid grid-cols-1 lg:grid-cols-2 gap-6" style="display: none;">
                {# Metastasis Locations #}
                <div class="bg-white rounded-lg border border-gray-200 p-6 shadow-sm">
                    <h3 class="text-lg font-semibold text-gray-800 mb-4">Metastasis Locations</h3>
                    <div class="h-64 flex items-center justify-center text-gray-400">
                        No metastasis location data available
                    </div>
                </div>

                {# Metastasis Summary #}
                <div class="bg-white rounded-lg border border-gray-200 p-6 shadow-sm">
                    <h3 class="text-lg font-semibold text-gray-800 mb-4">Metastasis Summary</h3>
                    <div class="bg-red-50 rounded-lg p-6 mb-4 text-center">
                        <p class="text-4xl font-bold text-wcm-red mb-2">0</p>
                        <p class="text-sm text-gray-600">patients with documented metastasis</p>
                        <p class="text-xs text-gray-500 mt-1">NaN% of cohort</p>
                    </div>
                    <div class="space-y-2">
                        <div class="flex justify-between items-center py-2 bg-gray-50 rounded px-3">
                            <span class="text-sm text-gray-600">Bone metastases</span>
                            <span class="text-sm font-medium text-gray-900">0</span>
                        </div>
                        <div class="flex justify-between items-center py-2 bg-gray-50 rounded px-3">
                            <span class="text-sm text-gray-600">Lymph node metastases</span>
                            <span class="text-sm font-medium text-gray-900">0</span>
                        </div>
                        <div class="flex justify-between items-center py-2 bg-gray-50 rounded px-3">
                            <span class="text-sm text-gray-600">Visceral metastases</span>
                            <span class="text-sm font-medium text-gray-900">0</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        function showTab(tabName) {
            // Hide all content sections
            document.querySelectorAll('.tab-content').forEach(function(el) {
                el.style.display = 'none';
            });
            
            // Show selected content
            document.getElementById('content-' + tabName).style.display = 'grid';
            
            // Reset all tab buttons
            document.querySelectorAll('[id^="tab-"]').forEach(function(el) {
                el.classList.remove('text-wcm-red', 'border-b-2', 'border-wcm-red');
                el.classList.add('text-gray-500');
            });
            
            // Highlight active tab
            document.getElementById('tab-' + tabName).classList.remove('text-gray-500');
            document.getElementById('tab-' + tabName).classList.add('text-wcm-red', 'border-b-2', 'border-wcm-red');
        }
    </script>
{% endblock %}
